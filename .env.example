# PIA Control Configuration
# Copy this file to .env and customize the values as needed

# Protocol to use for VPN connection
# Options: wireguard, openvpn
PIA_PROTOCOL=wireguard

# Default region selection
# Use "auto" for automatic selection, or specify a region name
PIA_DEFAULT_REGION=auto

# Whether to randomize region selection
# Options: true, false
PIA_RANDOMIZE_REGION=true

# Preferred regions (JSON array format)
# Example: ["us-east", "us-west", "europe"]
PIA_PREFERRED_REGIONS=[]

# Region filtering options
# Include streaming-optimized regions
PIA_REGION_FILTERS__include_streaming=false

# Include specific countries (JSON array format)
# Example: ["US", "CA", "GB"]
PIA_REGION_FILTERS__include_countries=[]

# Exclude specific countries (JSON array format)
# Example: ["CN", "RU"]
PIA_REGION_FILTERS__exclude_countries=[]

# Proxy configuration (if using a proxy)
# Proxy type
PIA_PROXY__KIND=socks5

# Proxy host (leave empty if not using proxy)
PIA_PROXY__HOST=

# Proxy port (leave empty if not using proxy)
PIA_PROXY__PORT=

# Proxy username (leave empty if not using proxy)
PIA_PROXY__USERNAME=

# Proxy password (leave empty if not using proxy)
PIA_PROXY__PASSWORD=

# Plugin configuration (JSON array format)
# Example: ["plugin1", "plugin2"]
PIA_PLUGINS=[]
